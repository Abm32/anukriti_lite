OPENAI_API_KEY=your_openai_api_key_here
PINECONE_API_KEY=your_pinecone_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Legacy pod-era setting only; do NOT put an API key here. Serverless: omit or leave empty.
PINECONE_ENV=
PINECONE_INDEX=drug-index

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------

# CORS: comma-separated list of allowed origins.
# Leave empty to allow all origins (development only).
# Production example: ALLOWED_ORIGINS=https://anukriti.abhimanyurb.com,https://app.example.com
ALLOWED_ORIGINS=

# API key authentication.
# Set API_KEY_REQUIRED=true and provide one or more keys to enable auth.
# Multiple keys: API_KEYS=key1,key2,key3
API_KEY_REQUIRED=false
API_KEYS=

# Maximum JSON request body size (bytes). Default 10 MB.
MAX_REQUEST_BODY_BYTES=10485760

# Maximum VCF upload size (bytes). Default 5 GB.
MAX_VCF_UPLOAD_BYTES=5368709120

# VCF upload session TTL (seconds). Sessions older than this are auto-cleaned. Default 24h.
VCF_UPLOAD_TTL_SECONDS=86400

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# LOG_FORMAT=json emits structured JSON lines (recommended for production).
# LOG_FORMAT=plain emits human-readable text (default for development).
LOG_FORMAT=plain

# Vector DB backend: pinecone (default) | auto | opensearch | qdrant | mock | local
VECTOR_DB_BACKEND=pinecone

# Embedding backend: bedrock (default, Amazon Titan) | local (sentence-transformers)
EMBEDDING_BACKEND=bedrock
# Model for local embeddings (used when EMBEDDING_BACKEND=local)
# EMBEDDING_LOCAL_MODEL=NeuML/pubmedbert-base-embeddings

# AWS OpenSearch vector search (used when VECTOR_DB_BACKEND=opensearch or auto)
# Example host: your-collection-id.us-east-1.aoss.amazonaws.com (no https://)
OPENSEARCH_HOST=
OPENSEARCH_INDEX=drug-index
OPENSEARCH_REGION=us-east-1
OPENSEARCH_SERVICE=aoss
OPENSEARCH_VECTOR_FIELD=vector
OPENSEARCH_TOP_K=3

# Qdrant vector search (used when VECTOR_DB_BACKEND=qdrant)
# Docker Compose (recommended): QDRANT_URL=http://qdrant:6333
# Local host run: QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
# QDRANT_PATH=data/qdrant_storage
# QDRANT_COLLECTION=drug-index

# Optional: sklearn reranker for local similar-drug search (train: python scripts/train_drug_reranker.py)
# DRUG_RERANKER_PATH=data/models/drug_reranker.joblib
# DRUG_RERANKER_POOL=40

API_URL=http://127.0.0.1:8000
API_TIMEOUT=180

# LLM call hard timeout (seconds). Applies to Bedrock (connect=10s, read=this value)
# and Gemini/Anthropic chains. Default 60s.
LLM_CALL_TIMEOUT_SECONDS=60

# Anthropic Claude (Direct API - not via Bedrock)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

LLM_BACKEND=nova
BEDROCK_REGION=us-east-1
TITAN_EMBED_MODEL=amazon.titan-embed-text-v2:0
CLAUDE_MODEL=anthropic.claude-3-sonnet-20240229-v1:0
Claude_MODEL_HAIKU=anthropic.claude-3-haiku-20240307-v1:0

# Amazon Nova Lite / Pro - PGx explanations via Bedrock (Converse API)
# Legacy NOVA_MODEL sets the Lite model ID if NOVA_LITE_MODEL is unset
NOVA_DEFAULT_VARIANT=lite
NOVA_LITE_MODEL=amazon.nova-lite-v1:0
NOVA_PRO_MODEL=amazon.nova-pro-v1:0
# NOVA_MODEL=amazon.nova-lite-v1:0

# QVAC local LLM bridge (Colosseum partner track)
# Setup: cd qvac && npm install
# Then set LLM_BACKEND=qvac or select "QVAC (Local)" in Streamlit.
QVAC_ENABLED=true
QVAC_NODE_BIN=node
# QVAC_SCRIPT_PATH defaults to ./qvac/qvac_pgx_explain.mjs
QVAC_TIMEOUT_SECONDS=180
QVAC_MODEL_LABEL=LLAMA_3_2_1B_INST_Q4_0

# Solana proof provider configuration
# Use a Helius devnet/mainnet endpoint here for reliable sponsor-ready proof
# submission and transaction lookup. Public devnet is used when unset.
# SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=your_helius_key
SOLANA_RPC_URL=

# Optional keypair path used by /attestations/submit. If unset, Solana CLI's
# default keypair/config is used. The wallet needs devnet SOL for anchoring.
# SOLANA_KEYPAIR_PATH=/home/you/.config/solana/id.json
SOLANA_KEYPAIR_PATH=

# AWS Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_DEFAULT_REGION=us-east-1
AWS_ACCOUNT_ID=your_aws_account_id

# AWS S3 Configuration
AWS_S3_BUCKET_GENOMIC=synthatrial-genomic-data
AWS_S3_BUCKET_REPORTS=synthatrial-reports
AWS_S3_REGION=us-east-1

# AWS Lambda Configuration
AWS_LAMBDA_FUNCTION_NAME=synthatrial-batch-processor
AWS_LAMBDA_REGION=us-east-1

# AWS Step Functions Configuration
AWS_STEP_FUNCTIONS_STATE_MACHINE=arn:aws:states:us-east-1:YOUR_ACCOUNT_ID:stateMachine:synthatrial-trial-orchestrator
AWS_STEP_FUNCTIONS_REGION=us-east-1

# Population Simulation Configuration
POPULATION_SIMULATOR_MAX_COHORT_SIZE=10000
POPULATION_SIMULATOR_BATCH_SIZE=100
POPULATION_SIMULATOR_ENABLE_LAMBDA=true

GEMINI_TEMPERATURE=0.1
LOG_LEVEL=INFO
ENVIRONMENT=development

# Timeout Configuration
HEALTH_CHECK_TIMEOUT=3
HEALTH_DETAILED_TIMEOUT=30
VCF_PROFILE_TIMEOUT=300
API_TIMEOUT=180
AWS_SERVICE_CHECK_TIMEOUT=10
CONFIG_VALIDATION_TIMEOUT=5

# Redis cache for VCF streaming (optional; reduces repeated HTTP range requests)
# Docker Compose (recommended): REDIS_URL=redis://redis:6379/0
# Local host run: REDIS_URL=redis://localhost:6379/0
# REDIS_VCF_CACHE_TTL=86400

# FHIR server for pushing genomic reports to EHR systems
# FHIR_SERVER_URL=http://localhost:8080/fhir
